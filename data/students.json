[
    {
        "id": "luo-yuhan",
        "name": "小罗",
        "title": "想要主动权的少年",
        "grade": "grade10",
        "gradeLabel": "高一",
        "color": "#c45c5c",
        "initial": "罗",
        "tags": ["高一", "一对一", "重点班"],
        "desc": "一个聪明的、在跟家庭管控系统做持续对抗的孩子。他偷买了手机被抓，从头到尾不认为自己错了。他说，"所有主动权掌握在自己手上不一样"。他不是想要手机，他想要一点自己能掌控的东西。",
        "info": {
            "学校": "南昌某重点班",
            "班型": "一对一",
            "科目": "语文",
            "上课时间": "周六晚"
        },
        "story": [
            {
                "date": "那个周六晚上",
                "text": "他花540块压岁钱偷偷买了一部手机。快递盒没扔，他妈看到盒子上的信息冲进房间，他手忙脚乱想塞被子里，没塞成。坐下来跟我聊这件事，他的第一反应是——"我感觉我一点错都没有。""
            },
            {
                "date": "不是手机的事",
                "text": "后来他说了实话。他想要的不是手机，是"主动权掌握在自己手上"。他不是在跟妈妈对着干，他是在跟他妈签的那个游戏协议较劲。每周玩1小时抵2小时，周一到周五不碰手机，欠的36小时游戏时间要慢慢还清。在他眼里，这不是一个公平的协议。"
            },
            {
                "date": "然后他哭了",
                "text": "我跟他聊了很久。最后我说，"我给你解释了半天这件事，你如果还是这个态度，那只能说我们两个师生关系要走到尽头了。"他一下子就转泪了。他哭不是因为觉得自己错了，是因为他在意的是关系，不是规则。"
            },
            {
                "date": "三层方案",
                "text": "我给了他一个方案。第一层：我去跟他妈谈，争取正规途径给他一部手机。第二层：谈不通，我自己掏钱买给他，但锁在我手里。第三层：如果被发现，我退全部课时费，一拍两散。他说"这点钱对你来讲算个鸡毛"——他不相信一个老师愿意为他赔钱。我告诉他我有两套房子。他不再反驳了。"
            },
            {
                "date": "期中成绩出来了",
                "text": "语文88，数学115，英语106，物理46，化学26，生物51。总分432，全班第50名。化学26不是学不懂，是根本没在学。他这半个月的精力全花在手机那件事上了。但好消息是——以他的性格，这个成绩会让他自己收着一段时间。"
            },
            {
                "date": "他妈的回复",
                "text": "我给他妈发了长消息，告诉她孩子的心态、哭了的原因、信任感的问题。她回了一句："就他这种逻辑，跟他说得清吗，就永远长不大。"她还是站在"孩子是错的"那个位置上。我没展开。不急，等她自己走到"那你觉得怎么办"那一步。"
            },
            {
                "date": "未完待续",
                "text": "他答应了我，不再用自己臆想的方案。故事还在继续。"
            }
        ]
    },
    {
        "id": "yang-ziling",
        "name": "小泠",
        "title": "安静地退出参与的孩子",
        "grade": "grade8",
        "gradeLabel": "八年级",
        "color": "#5ca0a0",
        "initial": "泠",
        "tags": ["八年级", "一对一", "语文"],
        "desc": "她不打架不顶嘴，只是安静地退出了参与。她写杀手题材的OC故事，对主流叙事嗤之以鼻。不是叛逆，是失望。",
        "info": {
            "学校": "南昌某中学",
            "班型": "一对一",
            "科目": "语文",
            "上课时间": "周六上午"
        },
        "story": [
            {
                "date": "最初的印象",
                "text": "她外冷内热，有主见，敏感。上课的时候教了不接，逼了应付，怎么都走进不了内心。她不是学不会，是不想学给你看。"
            },
            {
                "date": "OC创作",
                "text": "她写杀手题材的原创角色故事，主角叫洛蔷薇、柳泉、沈江。这些故事不是消遣——这是她的世界。在那个世界里，她得到的反馈是真实的，不像大人只会说好听的话。"
            },
            {
                "date": "妈妈的温柔",
                "text": "她的妈妈对外发光，对内缺位。朋友圈发千叟素宴"温柔暖洪城""德孝传家"，筹办1000人的活动。但女儿每天微信2.5小时没人管。妈妈的温柔是"给所有人的"，不是只给她的。所以她退回到自己的世界。"
            },
            {
                "date": "《刺猬》",
                "text": "我给她写了一篇阅读理解，叫《刺猬》。写的是一个画画的同学，安静、敏感、有自己不被理解的世界。围绕它出了5道题——环境描写、词语赏析、人物分析、标题分析、句意理解。材料换成了她会读进去的东西，但设问方式和江西省中考真题一致。她读进去了。那一刻她是投入的。"
            },
            {
                "date": "《墨隐记》和《谷中兰》",
                "text": "后来又写了一篇文言文《墨隐记》——不善言辞的人画满墙壁，非无言也有所待。还有诗经体《谷中兰》，三章重章叠句。她喜欢这些。不是因为她在学语文，是因为这些文字里有她。"
            },
            {
                "date": "未完待续",
                "text": "我不知道她会不会打开那扇门。但我知道她读《刺猬》的那一刻，她是投入的。那就够了。"
            }
        ]
    },
    {
        "id": "wang-yinuo",
        "name": "小渃",
        "title": "在重点班失去坐标的少年",
        "grade": "grade10",
        "gradeLabel": "高一",
        "color": "#7a6ad4",
        "initial": "渃",
        "tags": ["高一", "一对二", "语文"],
        "desc": "他从普通班考进重点班，然后垫底了。曾经的成绩是他的坐标，现在坐标没了，他不知道自己是谁。",
        "info": {
            "学校": "南昌某重点班",
            "班型": "一对二",
            "科目": "语文",
            "上课时间": "周日上午"
        },
        "story": [
            {
                "date": "播音主持",
                "text": "他报了学校的播音主持，被选上了。妈妈很紧张，觉得他不务正业。但我觉得，他在播音里找到了重点班给不了他的东西——存在感。他不是想当主持人，他是想在一个地方被看见。"
            },
            {
                "date": "妈妈的消息",
                "text": "妈妈发来一段话："好一点的大学和普通高校差别确实大。他如果是没有能力我也就不焦虑。但现在是他没有去奋斗。"她说得有道理。但她不知道的是——他不是不想奋斗，是找不到奋斗的理由。"
            },
            {
                "date": "未完待续",
                "text": "不要提成绩。重点班中失去成就感是根本原因。长期目标高三全托，现在做的一切是存信任。"
            }
        ]
    },
