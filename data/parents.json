        "info": {
            "学校": "南昌某中学",
            "班型": "一对一",
            "科目": "语文",
            "上课时间": "周六上午"
        },
        "story": [
            {
                "date": "最初的印象",
                "text": "泠泠外冷内热，有主见，敏感。上课的时候不太愿意主动表达，但她不是学不会，是需要找到她愿意投入的方式。"
            },
            {
                "date": "找到切入点",
                "text": "我发现她对文字创作有兴趣，就从这个方向入手。给她写了定制的阅读材料，围绕她的世界出了题。她读进去了，那一刻她是投入的。"
            },
            {
                "date": "期中前",
                "text": "这段时间我在用新的方式跟她上课，效果还需要观察。有进展会跟您说。"
            }
        ]
    },
