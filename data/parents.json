[
    {
        "id": "luo-yuhan",
        "name": "小罗",
        "title": "想要主动权的少年",
        "grade": "grade10",
        "gradeLabel": "高一",
        "color": "#c45c5c",
        "initial": "罗",
        "tags": [
            "高一",
            "一对一",
            "重点班"
        ],
        "desc": "一个聪明的、在跟家庭管控系统做持续对抗的孩子。他偷买了手机被抓，从头到尾不认为自己错了。他说，「所有主动权掌握在自己手上不一样」。他不是想要手机，他想要一点自己能掌控的东西。",
        "info": {
            "学校": "南昌某重点班",
            "班型": "一对一",
            "科目": "语文",
            "上课时间": "周六晚"
        },
        "story": [
            {
                "date": "那个周六晚上",
                "text": "他花540块压岁钱偷偷买了一部手机，被发现后坐下来跟我聊。他的第一反应是感觉自己一点错都没有。"
            },
            {
                "date": "不是手机的事",
                "text": "后来他说了实话。他想要的不是手机，是「主动权掌握在自己手上」。他不是在跟您对着干，他是在跟那个游戏协议较劲——在他眼里，那不是一个公平的协议。"
            },
            {
                "date": "他哭了",
                "text": "我跟他说，如果他还是这个态度，师生关系可能要走到尽头。他一下子就哭了。他哭不是因为觉得自己错了，是因为他在意的是关系，不是规则。这个孩子在意的人不多，但他真的在意。"
            },
            {
                "date": "我的方案",
                "text": "我给了他一个方案，他答应了不再自己想办法。接下来我会跟您详细聊，看看怎么从根本上解决这个问题。"
            },
            {
                "date": "期中成绩",
                "text": "总分432，全班第50名。化学26、物理46不是学不懂，是这段时间精力全在手机事件上了。好消息是，以他的性格，这个成绩会让他自己收着一段时间。这段时间的配合度会高，我们抓紧用。"
            },
            {
                "date": "下一步",
                "text": "他的配合度在恢复。等时机到了我会跟您详细说我的方案。"
            }
        ]
    },
